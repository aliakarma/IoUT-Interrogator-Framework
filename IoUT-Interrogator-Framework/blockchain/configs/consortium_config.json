{
  "_comment": "Hyperledger Fabric permissioned consortium configuration template.",
  "_note": "This is a configuration reference. Full Fabric deployment requires Docker + fabric-samples.",
  "_reference": "Paper Section IV.D: 9 validators, PBFT consensus, surface-hosted majority.",

  "consortium": {
    "name": "IoUTTrustConsortium",
    "channel": "trust-channel",
    "consensus": "PBFT",
    "num_validators": 9,
    "fault_tolerance": 2,
    "comment_ft": "Tolerates floor((9-1)/3)=2 Byzantine validators"
  },

  "organizations": [
    {"name": "SurfaceGatewayOrg1", "msp_id": "SurfaceGW1MSP",  "role": "validator", "location": "surface"},
    {"name": "SurfaceGatewayOrg2", "msp_id": "SurfaceGW2MSP",  "role": "validator", "location": "surface"},
    {"name": "SurfaceGatewayOrg3", "msp_id": "SurfaceGW3MSP",  "role": "validator", "location": "surface"},
    {"name": "SurfaceGatewayOrg4", "msp_id": "SurfaceGW4MSP",  "role": "validator", "location": "surface"},
    {"name": "SurfaceGatewayOrg5", "msp_id": "SurfaceGW5MSP",  "role": "validator", "location": "surface"},
    {"name": "MissionControlOrg1", "msp_id": "MissionCtrl1MSP","role": "validator", "location": "surface"},
    {"name": "MissionControlOrg2", "msp_id": "MissionCtrl2MSP","role": "validator", "location": "surface"},
    {"name": "AUVOrg1",            "msp_id": "AUV1MSP",        "role": "validator", "location": "underwater"},
    {"name": "AUVOrg2",            "msp_id": "AUV2MSP",        "role": "validator", "location": "underwater"}
  ],

  "chaincode": {
    "name": "trust-ledger",
    "version": "1.0",
    "language": "golang",
    "path": "blockchain/chaincode/trust_ledger.go"
  },

  "ledger_policy": {
    "endorsement": "MAJORITY",
    "commit_type": "trust_delta_summary",
    "commit_trigger": "threshold_crossing",
    "comment": "Only agents crossing tau_min generate commit events; not all intervals"
  },

  "pbft_parameters": {
    "view_change_timeout_ms": 5000,
    "request_timeout_ms": 10000,
    "max_batch_size": 50,
    "max_batch_timeout_ms": 2000
  }
}
