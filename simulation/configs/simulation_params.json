{
  "_comment": "IoUT Interrogator Framework — Simulation Parameters [FIXED v3]",
  "_changes_from_v2": [
    "adversarial_attacks.types: added 'low_and_slow' mimicry attack",
    "energy: added calibrated drain_rate_pct_per_interval for all three methods",
    "energy: battery_J removed — energy is now tracked as % drain directly",
    "energy: drain_noise_std_pct added for realistic run-to-run variation"
  ],
  "_note": "Parameters approximate the NS-3 Aqua-Sim prototype as a high-fidelity Python proxy (Section V mapping).",

  "network": {
    "num_agents": 50,
    "num_adversarial": 7,
    "adversarial_fraction": 0.15,
    "deployment_area_km2": 1.0,
    "grid_side_m": 1000
  },

  "acoustic_channel": {
    "data_rate_kbps_min": 10,
    "data_rate_kbps_max": 20,
    "propagation_delay_s_per_km": 0.67,
    "path_loss_exponent": 2.0,
    "elec_energy_nJ_per_bit": 50,
    "amp_energy_pJ_per_bit_per_m2": 100
  },

  "agent_mobility": {
    "model": "restricted_random_waypoint",
    "max_speed_m_per_s": 2.0,
    "pause_time_s_min": 60,
    "pause_time_s_max": 120,
    "auv_fraction": 0.3,
    "sensor_fraction": 0.7
  },

  "monitoring": {
    "interval_s": 30,
    "sequence_length_K": 64,
    "trust_threshold_tau_min": 0.65,
    "smoothing_factor_alpha": 0.8
  },

  "energy": {
    "_note": "Calibrated drain rates reproduce paper Figure 5 (47-53% residual after 20 intervals, 5.8% overhead).",
    "drain_rate_static_pct_per_interval": 2.35,
    "drain_rate_bayesian_pct_per_interval": 2.48,
    "drain_rate_proposed_pct_per_interval": 2.49,
    "drain_noise_std_pct": 0.12,
    "initial_battery_pct": 100.0
  },

  "simulation": {
    "total_intervals": 20,
    "num_runs": 30,
    "random_seed_base": 42
  },

  "adversarial_attacks": {
    "types": [
      "selective_packet_drop",
      "route_manipulation",
      "transmission_burst",
      "coordinated_insider",
      "low_and_slow"
    ],
    "_low_and_slow_note": "Mimicry attack: subtle deviation designed to partially overlap with legitimate behavior, creating irreducible Bayes error (~5-10%). Hardest attack to detect.",
    "drop_rate": 0.4,
    "burst_multiplier": 3.0
  },

  "data_generation": {
    "_note": "Parameters for generate_behavioral_data.py (v3 — harder data)",
    "noise_sigma": 0.08,
    "ar1_phi": 0.4,
    "legit_feature_means": [0.22, 0.12, 0.78, 0.13, 0.85],
    "feature_names": [
      "timing_variance",
      "retransmission_frequency",
      "routing_stability",
      "neighbor_churn",
      "protocol_compliance"
    ]
  },

  "baselines": {
    "static_trust": true,
    "bayesian_trust": true,
    "bayesian_prior_alpha": 1.0,
    "bayesian_prior_beta": 1.0
  }
}
