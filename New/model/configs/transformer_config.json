{
  "_comment": "Transformer trust inference model configuration — matches paper Section IV.C",

  "architecture": {
    "input_dim": 5,
    "seq_len": 64,
    "d_model": 128,
    "num_heads": 4,
    "num_layers": 4,
    "d_ff": 256,
    "dropout": 0.1,
    "output_dim": 1,
    "output_activation": "sigmoid"
  },

  "quantization": {
    "enabled": true,
    "dtype": "int8",
    "backend": "fbgemm",
    "note": "Post-training static quantization reduces model to ~6-8 MB"
  },

  "training": {
    "epochs": 50,
    "batch_size": 32,
    "learning_rate": 1e-3,
    "weight_decay": 1e-4,
    "optimizer": "adam",
    "loss": "binary_cross_entropy",
    "train_split": 0.7,
    "val_split": 0.15,
    "test_split": 0.15,
    "early_stopping_patience": 10,
    "random_seed": 42
  },

  "trust_scoring": {
    "threshold_tau_min": 0.65,
    "smoothing_alpha": 0.8,
    "update_interval_s": 30
  },

  "hardware_targets": {
    "platform": "Jetson-class embedded GPU",
    "power_envelope_W": "5-10",
    "memory_MB": "6-8",
    "inference_latency_ms": "120-180",
    "energy_per_inference_J": "0.35-0.6"
  }
}
